{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/brennovmh/CHIK_FLOW/main/nextflow_schema.json",
  "title": "CHIK-FLOW pipeline parameters",
  "description": "Nextflow pipeline for chikungunya virus sequencing analysis",
  "type": "object",
  "$defs": {
    "input_output_options": {
      "title": "Input/output options",
      "type": "object",
      "properties": {
        "input": {
          "type": "string",
          "format": "file-path",
          "description": "CSV samplesheet with sample, fastq_1, fastq_2 columns."
        },
        "outdir": {
          "type": "string",
          "format": "directory-path",
          "description": "Output directory."
        },
        "reference_fasta": {
          "type": "string",
          "format": "file-path",
          "description": "FASTA reference panel used by downstream CHIKV modules."
        },
        "reference_gff": {
          "type": "string",
          "format": "file-path",
          "description": "Optional GFF annotation for reference panel records."
        }
      },
      "required": ["input", "outdir", "reference_fasta"]
    },
    "skip_options": {
      "title": "Process skipping options",
      "type": "object",
      "properties": {
        "skip_fastqc": {
          "type": "boolean",
          "description": "Skip FastQC."
        },
        "skip_fastp": {
          "type": "boolean",
          "description": "Skip fastp trimming."
        },
        "skip_multiqc": {
          "type": "boolean",
          "description": "Skip MultiQC."
        },
        "skip_reference_prep": {
          "type": "boolean",
          "description": "Skip reference panel validation."
        },
        "skip_alignment": {
          "type": "boolean",
          "description": "Skip BWA-MEM alignment and BAM processing."
        },
        "skip_coverage": {
          "type": "boolean",
          "description": "Skip per-base depth and coverage summary."
        }
      }
    }
  },
  "allOf": [
    {
      "$ref": "#/$defs/input_output_options"
    },
    {
      "$ref": "#/$defs/skip_options"
    }
  ]
}
